{% comment %}
  Banner Section - Minimal Version
{% endcomment %}

<section class="banner" id="banner-{{ section.id }}">
  
  <div class="bg">
    {% if section.settings.background_image != blank %}
      <img
        src="{{ section.settings.background_image | image_url: width: 2400 }}"
        alt="{{ section.settings.background_image.alt | escape }}"
        loading="eager"
      >
    {% else %}
      {{ 'image' | placeholder_svg_tag }}
    {% endif %}
  </div>

  <div class="content">

    {% if section.settings.subtitle != blank %}
      <p class="sub">{{ section.settings.subtitle }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="title">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="desc">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="btn">
        {{ section.settings.button_label }}
        <span class="arrow">→</span>
      </a>
    {% endif %}

  </div>
</section>

{% if section.settings.bottom_text != blank %}
  <div class="bottom" id="bottom-{{ section.id }}">
    {{ section.settings.bottom_text }}
  </div>
{% endif %}

<style>
  #banner-{{ section.id }} {
    --bg: {{ section.settings.section_bg_color }};
    --text: {{ section.settings.text_color }};
    --title: {{ section.settings.heading_color }};
    --btn-bg: {{ section.settings.button_bg_color }};
    --btn-text: {{ section.settings.button_text_color }};
    --btn-hover-bg: {{ section.settings.button_hover_bg_color }};
    --btn-hover-text: {{ section.settings.button_hover_text_color }};
    min-height: {{ section.settings.min_height }}px;
  }

  #banner-{{ section.id }},
  #bottom-{{ section.id }} {
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }

  .banner {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--bg);
  }

  .bg {
    position: absolute;
    inset: 0;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
  }

  .banner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(255,255,255,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(255,255,255,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 40%,
      transparent 70%
    );
  }

  .content {
    position: relative;
    z-index: 2;
    padding: 80px 6vw;
    max-width: 600px;
  }

  .sub {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .2em;
    opacity: .6;
    color: var(--text);
  }

  .title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin: 10px 0;
    color: var(--title);
  }

  .desc {
    margin-bottom: 30px;
    line-height: 1.6;
    color: var(--text);
  }

  .btn {
    display: inline-flex;
    gap: 10px;
    padding: 14px 26px;
    background: var(--btn-bg);
    color: var(--btn-text);
    text-decoration: none;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: .15em;
    transition: .3s;
  }

  .btn:hover {
    background: var(--btn-hover-bg);
    color: var(--btn-hover-text);
  }

  .bottom {
    padding: 20px;
    text-align: right;
    background: #f5f5f5;
    font-size: 13px;
    text-transform: uppercase;
  }

  @media(max-width:768px){
    .content { padding: 50px 20px; }
    .bottom { text-align: center; }
  }
</style>

{% schema %}
{
  "name": "Banner",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Image" },

    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "right center"
    },

    { "type": "text", "id": "subtitle", "label": "Subtitle" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "description", "label": "Description" },

    { "type": "text", "id": "bottom_text", "label": "Bottom Text" },

    { "type": "text", "id": "button_label", "label": "Button Label" },
    { "type": "url", "id": "button_link", "label": "Button Link" },

    { "type": "color", "id": "section_bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "heading_color", "label": "Heading", "default": "#111" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#111" },

    { "type": "color", "id": "button_bg_color", "label": "Button BG", "default": "#111" },
    { "type": "color", "id": "button_text_color", "label": "Button Text", "default": "#fff" },

    { "type": "color", "id": "button_hover_bg_color", "label": "Button Hover BG", "default": "#fff" },
    { "type": "color", "id": "button_hover_text_color", "label": "Button Hover Text", "default": "#111" },

    { "type": "range", "id": "overlay_opacity", "label": "Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 80 },

    { "type": "range", "id": "min_height", "label": "Height", "min": 300, "max": 900, "step": 10, "default": 560 }
  ],
  "presets": [
    { "name": "Banner" }
  ]
}
{% endschema %}
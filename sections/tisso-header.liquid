{% comment %}
  TISSO VISON — Custom Header Section
{% endcomment %}

<style>
  :root {
    --yellow: #F5E642;
    --black: #111111;
    --bg: #F2F0EC;
    --font: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .tisso-header {
    background-color: var(--bg);
    width: 100%;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    position: sticky;
    top: 0;
    z-index: 9999;
  }

  .tisso-header__desktop {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 64px;
  }

  .tisso-header__logo {
    font-family: var(--font);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--black);
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .tisso-header__tagline {
    font-family: var(--font);
    font-size: 14px;
    font-weight: 400;
    color: var(--black);
    letter-spacing: 0.01em;
    flex: 1;
    text-align: center;
    padding: 0 20px;
  }

  .tisso-header__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: var(--yellow);
    color: var(--black);
    text-decoration: none;
    font-family: var(--font);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 14px 24px;
    white-space: nowrap;
    transition: background-color 0.2s ease, transform 0.15s ease;
    border: none;
    cursor: pointer;
  }

  .tisso-header__cta:hover {
    background-color: #e8d800;
    transform: translateX(2px);
  }

  .tisso-header__cta-arrow {
    display: inline-block;
    font-size: 16px;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .tisso-header__cta:hover .tisso-header__cta-arrow {
    transform: translateX(4px);
  }

  .tisso-header__mobile {
    display: none;
    align-items: center;
    padding: 0 20px;
    height: 56px;
    gap: 20px;
  }

  .tisso-header__hamburger {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    flex-shrink: 0;
  }

  .tisso-header__hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: var(--black);
  }

  .tisso-header__mobile-logo {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--black);
    text-decoration: none;
    text-transform: uppercase;
    flex: 1;
    text-align: center;
  }

  .tisso-header__mobile-spacer {
    width: 30px;
    flex-shrink: 0;
  }

  .tisso-drawer {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--bg);
    z-index: 10000;
    flex-direction: column;
    transform: translateY(-100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tisso-drawer.is-open {
    transform: translateY(0);
  }

  .tisso-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    height: 56px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .tisso-drawer__close {
    background: none;
    border: none;
    font-size: 22px;
    cursor: pointer;
    color: var(--black);
    font-weight: 300;
    line-height: 1;
    padding: 4px;
  }

  .tisso-drawer__logo {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--black);
    text-decoration: none;
    text-transform: uppercase;
    flex: 1;
    text-align: center;
  }

  .tisso-drawer__spacer {
    width: 30px;
  }

  .tisso-drawer__body {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    flex: 1;
    justify-content: center;
  }

  .tisso-drawer__tagline {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 400;
    color: var(--black);
    text-align: center;
  }

  .tisso-drawer__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: var(--yellow);
    color: var(--black);
    text-decoration: none;
    font-family: var(--font);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 16px 32px;
    width: 100%;
    justify-content: center;
    max-width: 320px;
  }

  .tisso-drawer__cta:hover {
    background-color: #e8d800;
  }

  @media (max-width: 768px) {
    .tisso-header__desktop {
      display: none;
    }
    .tisso-header__mobile {
      display: flex;
    }
    .tisso-drawer {
      display: flex;
    }
  }
</style>

<header class="tisso-header" role="banner">
  <div class="tisso-header__desktop">
    <a href="{{ routes.root_url }}" class="tisso-header__logo">
      {{ section.settings.logo_text | default: 'TISSO VISON' }}
    </a>
    <p class="tisso-header__tagline">
      {{ section.settings.tagline | default: 'Find the ideal gift for your loved ones.' }}
    </p>
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="tisso-header__cta">
      {{ section.settings.cta_text | default: 'CHOOSE GIFT' }}
      <span class="tisso-header__cta-arrow">&#8594;</span>
    </a>
  </div>

  <div class="tisso-header__mobile">
    <button class="tisso-header__hamburger" aria-label="Open menu" id="tisso-open-drawer">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <a href="{{ routes.root_url }}" class="tisso-header__mobile-logo">
      {{ section.settings.logo_text | default: 'TISSO VISON' }}
    </a>
    <div class="tisso-header__mobile-spacer"></div>
  </div>
</header>

<div class="tisso-drawer" id="tisso-drawer" role="dialog" aria-modal="true">
  <div class="tisso-drawer__header">
    <button class="tisso-drawer__close" id="tisso-close-drawer" aria-label="Close menu">&#x2715;</button>
    <a href="{{ routes.root_url }}" class="tisso-drawer__logo">
      {{ section.settings.logo_text | default: 'TISSO VISON' }}
    </a>
    <div class="tisso-drawer__spacer"></div>
  </div>
  <div class="tisso-drawer__body">
    <p class="tisso-drawer__tagline">
      {{ section.settings.tagline | default: 'Find the ideal gift for your loved ones.' }}
    </p>
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="tisso-drawer__cta">
      {{ section.settings.cta_text | default: 'CHOOSE GIFT' }}
      <span>&#8594;</span>
    </a>
  </div>
</div>

<script>
  (function () {
    var openBtn = document.getElementById('tisso-open-drawer');
    var closeBtn = document.getElementById('tisso-close-drawer');
    var drawer = document.getElementById('tisso-drawer');

    function openDrawer() {
      drawer.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    openBtn && openBtn.addEventListener('click', openDrawer);
    closeBtn && closeBtn.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeDrawer();
    });
  })();
</script>

{% schema %}
{
  "name": "Tisso Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo / Brand Name",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Tisso Header"
    }
  ]
}
{% endschema %}